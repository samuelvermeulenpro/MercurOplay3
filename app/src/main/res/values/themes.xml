<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.MercurOplay" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_blue</item>
        <item name="colorPrimaryDark">@color/brand_blue_dark</item>
        <item name="colorAccent">@color/brand_orange</item>
        <item name="colorSecondary">@color/brand_orange</item>
        <item name="android:statusBarColor">@color/brand_blue_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:navigationBarColor">@color/brand_blue_dark</item>
        <item name="android:windowBackground">@color/background_light</item>
    </style>

    <style name="Theme.MercurOplay.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/brand_white</item>
        <item name="android:statusBarColor">@color/brand_white</item>
        <item name="android:navigationBarColor">@color/brand_white</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>

    <style name="Widget.MercurOplay.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView.Colored">
        <item name="android:background">@color/brand_blue</item>
        <item name="itemIconTint">@color/bottom_nav_item_color</item>
        <item name="itemTextColor">@color/bottom_nav_item_color</item>
    </style>
</resources>
